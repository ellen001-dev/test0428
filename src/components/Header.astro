---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-accent-dark px-3 py-2 text-white backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="relative z-40 w-full bg-accent-dark"
>
  <div
    id="top-nav-wrap"
    class="mx-auto flex w-full max-w-5xl items-center justify-between px-4 py-4"
  >
    <a
      href="/"
      class="text-xl font-bold text-white sm:text-2xl"
    >
      ServiceToolBase <span class="text-accent">Reviews</span>
    </a>
    <nav
      id="nav-menu"
      class="flex items-center justify-end gap-2 sm:gap-6"
    >
      <button
        id="menu-btn"
        class="focus-outline p-2 text-white sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden text-white" />
        <IconMenuDeep id="menu-icon" class="text-white" />
      </button>
      <ul
        id="menu-items"
        class="hidden items-center gap-2 sm:flex sm:gap-4"
      >
        <li>
          <a 
            href="/reviews" 
            class:list={[
              "px-3 py-2 font-medium text-white hover:text-accent transition-colors",
              { "text-accent": isActive("/reviews") }
            ]}
          >
            深度评测
          </a>
        </li>
        <li>
          <a 
            href="/compare" 
            class:list={[
              "px-3 py-2 font-medium text-white hover:text-accent transition-colors",
              { "text-accent": isActive("/compare") }
            ]}
          >
            竞品对比
          </a>
        </li>
        <li>
          <a 
            href="/hvac-software" 
            class:list={[
              "px-3 py-2 font-medium text-white hover:text-accent transition-colors",
              { "text-accent": isActive("/hvac-software") }
            ]}
          >
            工种指南
          </a>
        </li>
        <li>
          <a 
            href="/housecall-pro-pricing" 
            class:list={[
              "px-3 py-2 font-medium text-white hover:text-accent transition-colors",
              { "text-accent": isActive("/housecall-pro-pricing") }
            ]}
          >
            定价分析
          </a>
        </li>
        <li>
          <a 
            href="/posts" 
            class:list={[
              "px-3 py-2 font-medium text-white hover:text-accent transition-colors",
              { "text-accent": isActive("/posts") }
            ]}
          >
            全部文章
          </a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <LinkButton
                href="/archives"
                class="focus-outline p-2 hover:text-accent transition-colors"
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="inline-block text-white" />
              </LinkButton>
            </li>
          )
        }
        <li>
          <LinkButton
            href="/search"
            class="focus-outline p-2 hover:text-accent transition-colors"
            title="Search"
            aria-label="search"
          >
            <IconSearch class="text-white" />
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li>
              <button
                id="theme-btn"
                class="focus-outline p-2 hover:text-accent transition-colors"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90 text-white" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0 text-white" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
  
  <!-- Mobile Menu -->
  <div 
    id="mobile-menu"
    class="hidden bg-accent-dark p-4 sm:hidden"
  >
    <ul class="flex flex-col gap-2">
      <li>
        <a 
          href="/reviews" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          深度评测
        </a>
      </li>
      <li>
        <a 
          href="/compare" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          竞品对比
        </a>
      </li>
      <li>
        <a 
          href="/hvac-software" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          工种指南
        </a>
      </li>
      <li>
        <a 
          href="/housecall-pro-pricing" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          定价分析
        </a>
      </li>
      <li>
        <a 
          href="/posts" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          全部文章
        </a>
      </li>
      <li>
        <a 
          href="/tags" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          标签
        </a>
      </li>
      <li>
        <a 
          href="/about" 
          class="block px-4 py-3 font-medium text-white hover:bg-accent/10 rounded-lg"
        >
          关于
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      mobileMenu?.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
