---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[className]}
  {...attrs}
>
  <!-- Main Footer -->
  <div class="bg-accent-dark py-12">
    <div class="mx-auto w-full max-w-5xl px-4">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Brand -->
        <div>
          <a href="/" class="text-xl font-bold text-white">
            ServiceToolBase
          </a>
          <p class="mt-4 text-sm text-gray-400">
            Independent reviews of contractor software. 
            Written by contractors, for contractors.
          </p>
        </div>
        
        <!-- Category Navigation -->
        <div>
          <h4 class="mb-4 font-semibold text-white">Category Navigation</h4>
          <ul class="space-y-2">
            <li>
              <a href="https://www.servicetoolbase.com/reviews/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Software Reviews
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/compare/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Comparisons
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/hvac-software/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Trade Guides
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/housecall-pro-pricing/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Pricing Breakdown
              </a>
            </li>
          </ul>
        </div>
        
        <!-- Quick Links -->
        <div>
          <h4 class="mb-4 font-semibold text-white">Quick Links</h4>
          <ul class="space-y-2">
            <li>
              <a href="https://www.servicetoolbase.com/posts/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                All Articles
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/tags/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Tags
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/about/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                About Us
              </a>
            </li>
          </ul>
        </div>
        
        <!-- Contact -->
        <div>
          <h4 class="mb-4 font-semibold text-white">Contact</h4>
          <ul class="space-y-2">
            <li>
              <a href="#" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Submit Review
              </a>
            </li>
            <li>
              <a href="#" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Advertise
              </a>
            </li>
            <li>
              <a href="#" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Press Kit
              </a>
            </li>
            <li>
              <a href="https://www.servicetoolbase.com/privacy-policy/" class="text-sm text-gray-400 hover:text-accent transition-colors">
                Privacy Policy
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Copyright -->
  <div class="bg-background border-t border-border py-4">
    <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-4">
      <div class="text-sm text-muted-foreground">
        Copyright &#169; {currentYear} ServiceToolBase. All rights reserved.
      </div>
      <div class="flex items-center gap-4">
        <Socials />
      </div>
    </div>
  </div>
</footer>