---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const comparePosts = posts.filter(({ data }) => data.category === "compare");
---

<Layout title="竞品对比 | ServiceToolBase Reviews">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold sm:text-4xl">竞品对比</h1>
      <p class="mt-2 text-gray-500">横向对比不同服务管理软件，帮你找到最适合的解决方案</p>
    </div>
    
    {comparePosts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {comparePosts.map((post) => (
          <Card
            href={`/posts/${post.slug}`}
            title={post.data.title}
            datetime={post.data.pubDatetime}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">暂无竞品对比文章，敬请期待！</p>
      </div>
    )}
  </main>
  
  <Footer />
