---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const comparePosts = posts.filter(({ data }) => data.category === "compare");
---

<Layout title="Comparisons | ServiceToolBase">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold sm:text-4xl">Comparisons</h1>
      <p class="mt-2 text-gray-500">Side-by-side comparisons to help you make smart choices</p>
    </div>
    
    {comparePosts.length > 0 ? (
      <ul>
        {comparePosts.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">No comparison articles yet. Stay tuned!</p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>