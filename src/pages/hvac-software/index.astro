---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const hubPosts = posts.filter(({ data }) => data.category === "hub");
---

<Layout title="Trade Guides | ServiceToolBase">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold sm:text-4xl">Trade Guides</h1>
      <p class="mt-2 text-gray-500">Specialized software guides for HVAC, plumbing, electrical, and more</p>
    </div>
    
    {hubPosts.length > 0 ? (
      <ul>
        {hubPosts.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">No trade guide articles yet. Stay tuned!</p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>