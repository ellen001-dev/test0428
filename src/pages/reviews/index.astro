---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const reviewPosts = posts.filter(({ data }) => data.category === "reviews");
---

<Layout title="品牌深度评测 | ServiceToolBase Reviews">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold sm:text-4xl">品牌深度评测</h1>
      <p class="mt-2 text-gray-500">深入分析各类服务管理软件的功能、定价和用户体验</p>
    </div>
    
    {reviewPosts.length > 0 ? (
      <ul>
        {reviewPosts.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">暂无品牌评测文章，敬请期待！</p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>