---
import type { GetStaticPaths } from "astro";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const reviewPosts = posts.filter(({ data }) => data.category === "reviews");
  return paginate(getSortedPosts(reviewPosts), { pageSize: 8 });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<"blog">> };
const { page } = Astro.props;
---

<Layout title="Contractor Software Reviews - Real Costs & Honest Ratings | ServiceToolBase" description="In-depth reviews of field service management software. Real pricing, real pros & cons, and user ratings from actual contractors.">
  <Header />

  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <img src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=hand%20holding%20smartphone%20with%205%20star%20rating%20review%20on%20blue%20background%20minimalist%203d%20illustration&image_size=landscape_16_9" alt="Software Reviews" class="w-full h-48 object-cover rounded-lg mb-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Software Reviews</h1>
      <p class="mt-2 text-gray-500">In-depth analysis of field service software features, pricing, and user experience</p>
    </div>

    {page.data.length > 0 ? (
      <ul>
        {page.data.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">No review articles yet. Stay tuned!</p>
      </div>
    )}
  </main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>