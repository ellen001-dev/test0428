---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPath } from "@/utils/getPath";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const reviewPosts = posts.filter(({ data }) => data.category === "reviews");
const comparePosts = posts.filter(({ data }) => data.category === "compare");
const hubPosts = posts.filter(({ data }) => data.category === "hub");
const pricingPosts = posts.filter(({ data }) => data.category === "pricing");
---

<Layout>
  <Header />
  
  <!-- Hero Section -->
  <section class="bg-accent-dark text-white">
    <div class="mx-auto w-full max-w-5xl px-4 py-16 sm:py-24">
      <h1 class="text-4xl font-bold leading-tight sm:text-5xl md:text-6xl">
        ServiceToolBase Management Software: Tested & Ranked for Small Teams.
<br />
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-gray-300">
        Real screenshots. Real costs. No vendor bias. Find the right tool for your HVAC, plumbing, or electrical business.

      </p>
      
      <!-- CTA Button -->
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a 
          href="/reviews" 
          class="inline-flex items-center justify-center gap-2 bg-accent px-8 py-4 font-semibold text-white hover:bg-accent-light transition-colors"
        >
          Browse All Reviews
          <IconArrowRight width={20} height={20} />
        </a>
        <a 
          href="/about" 
          class="inline-flex items-center justify-center gap-2 border-2 border-white/30 px-8 py-4 font-semibold text-white hover:bg-white/10 transition-colors"
        >
          Learn More
        </a>
      </div>

      <!-- Quick Stats Cards -->
      <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="bg-white/10 p-4 backdrop-blur-sm">
          <div class="text-3xl font-bold text-accent">{reviewPosts.length}</div>
          <div class="text-sm text-gray-300">Reviews</div>
        </div>
        <div class="bg-white/10 p-4 backdrop-blur-sm">
          <div class="text-3xl font-bold text-accent">{comparePosts.length}</div>
          <div class="text-sm text-gray-300">Comparisons</div>
        </div>
        <div class="bg-white/10 p-4 backdrop-blur-sm">
          <div class="text-3xl font-bold text-accent">{hubPosts.length}</div>
          <div class="text-sm text-gray-300">Guides</div>
        </div>
        <div class="bg-white/10 p-4 backdrop-blur-sm">
          <div class="text-3xl font-bold text-accent">{pricingPosts.length}</div>
          <div class="text-sm text-gray-300">Pricing</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Reviews Section -->
  <main id="main-content" data-layout="index" class="bg-background">
    {
      reviewPosts.length > 0 && (
        <section class="mx-auto w-full max-w-5xl px-4 py-12">
          <div class="mb-8 flex items-center justify-between">
            <h2 class="text-2xl font-bold text-foreground">Featured Reviews</h2>
            <a href="/reviews" class="text-accent hover:underline">View All</a>
          </div>
          
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {reviewPosts.slice(0, 3).map(post => (
              <article class="group overflow-hidden rounded-lg border border-border bg-card-bg p-6 shadow-sm transition-all hover:shadow-lg">
                <div class="mb-4 flex items-center gap-2 list-none">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span 
                      class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="mb-2 text-xl font-bold text-foreground group-hover:text-accent transition-colors">
                  {post.data.title}
                </h3>
                <p class="mb-4 text-sm text-muted-foreground line-clamp-2">
                  {post.data.description}
                </p>
                <a 
                  href={getPath(post.id, post.filePath, true, post.data.category)} 
                  class="inline-flex items-center gap-2 text-accent hover:gap-3 transition-all"
                >
                  Read Review
                  <IconArrowRight width={16} height={16} />
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <!-- Categories Section -->
    <section class="bg-muted/50 py-12">
      <div class="mx-auto w-full max-w-5xl px-4">
        <h2 class="mb-8 text-2xl font-bold text-foreground">Explore Categories</h2>
        
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a 
            href="/reviews"
            class="group flex flex-col items-center justify-center rounded-lg border border-border bg-card-bg p-6 text-center transition-all hover:border-accent hover:shadow-md"
          >
            <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-2xl font-bold text-accent">
              📊
            </div>
            <span class="font-medium text-foreground group-hover:text-accent transition-colors">
              深度评测
            </span>
            <span class="mt-1 text-xs text-muted-foreground">
              {reviewPosts.length} 篇文章
            </span>
          </a>
          
          <a 
            href="/compare"
            class="group flex flex-col items-center justify-center rounded-lg border border-border bg-card-bg p-6 text-center transition-all hover:border-accent hover:shadow-md"
          >
            <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-2xl font-bold text-accent">
              ⚖️
            </div>
            <span class="font-medium text-foreground group-hover:text-accent transition-colors">
              竞品对比
            </span>
            <span class="mt-1 text-xs text-muted-foreground">
              {comparePosts.length} 篇文章
            </span>
          </a>
          
          <a 
            href="/hvac-software"
            class="group flex flex-col items-center justify-center rounded-lg border border-border bg-card-bg p-6 text-center transition-all hover:border-accent hover:shadow-md"
          >
            <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-2xl font-bold text-accent">
              🔧
            </div>
            <span class="font-medium text-foreground group-hover:text-accent transition-colors">
              工种指南
            </span>
            <span class="mt-1 text-xs text-muted-foreground">
              {hubPosts.length} 篇文章
            </span>
          </a>
          
          <a 
            href="/housecall-pro-pricing"
            class="group flex flex-col items-center justify-center rounded-lg border border-border bg-card-bg p-6 text-center transition-all hover:border-accent hover:shadow-md"
          >
            <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-2xl font-bold text-accent">
              💰
            </div>
            <span class="font-medium text-foreground group-hover:text-accent transition-colors">
              定价分析
            </span>
            <span class="mt-1 text-xs text-muted-foreground">
              {pricingPosts.length} 篇文章
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Recent Comparisons Section -->
    {
      comparePosts.length > 0 && (
        <section class="mx-auto w-full max-w-5xl px-4 py-12">
          <div class="mb-8 flex items-center justify-between">
            <h2 class="text-2xl font-bold text-foreground">Recent Comparisons</h2>
            <a href="/compare" class="text-accent hover:underline">View All</a>
          </div>
          
          <div class="grid gap-4 sm:grid-cols-2">
            {comparePosts.slice(0, 2).map(post => (
              <article class="flex gap-4 rounded-lg border border-border bg-card-bg p-4 hover:border-accent/50 transition-colors">
                <div class="flex-1">
                  <h3 class="mb-1 text-lg font-semibold text-foreground hover:text-accent transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-muted-foreground line-clamp-2">
                    {post.data.description}
                  </p>
                </div>
                <div class="flex flex-col items-end justify-between">
                  <span class="rounded-full bg-accent/10 px-2 py-1 text-xs font-medium text-accent">
                    {post.data.tags[0] || "Compare"}
                  </span>
                  <time class="text-xs text-muted-foreground">
                    {new Date(post.data.pubDatetime).toLocaleDateString("zh-CN")}
                  </time>
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <!-- CTA Section -->
    <section class="bg-accent-dark py-16">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          The Work Behind the Call
        </h2>
        <p class="mt-4 text-gray-300">
          Every review is written by a contractor, for contractors. We don't accept 
          advertising or sponsored content - our opinions are 100% independent.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row justify-center">
          <a 
            href="/reviews" 
            class="inline-flex items-center justify-center gap-2 bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-light transition-colors"
          >
            Start Exploring
          </a>
          <a 
            href="/about" 
            class="inline-flex items-center justify-center gap-2 border-2 border-white/30 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors"
          >
            About Us
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>