---
import type { GetStaticPaths } from "astro";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";
import HousecallProPricingImage from "@/assets/images/housecall-pro-pricing.jpg";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const pricingPosts = posts.filter(({ data }) => data.category === "pricing");
  return paginate(getSortedPosts(pricingPosts), { pageSize: 8 });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<"blog">> };
const { page } = Astro.props;
---

<Layout title="Contractor Software Pricing Analysis - Hidden Costs Exposed | ServiceToolBase" description="Transparent pricing breakdowns of field service software. Learn what vendors don't show you and avoid unexpected costs.">
  <Header />

  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <img src={HousecallProPricingImage.src} alt="Housecall Pro Pricing" class="w-full h-48 object-cover rounded-lg mb-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Pricing Breakdown</h1>
      <p class="mt-2 text-gray-500">Uncover pricing strategies and avoid hidden fees and traps</p>
    </div>

    {page.data.length > 0 ? (
      <ul>
        {page.data.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">No pricing analysis articles yet. Stay tuned!</p>
      </div>
    )}
  </main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>