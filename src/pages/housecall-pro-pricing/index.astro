---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const pricingPosts = posts.filter(({ data }) => data.category === "pricing");
---

<Layout title="定价透明分析 | ServiceToolBase Reviews">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold sm:text-4xl">定价透明分析</h1>
      <p class="mt-2 text-gray-500">揭秘软件定价策略，帮你避免隐藏费用和陷阱</p>
    </div>
    
    {pricingPosts.length > 0 ? (
      <ul>
        {pricingPosts.map((post) => (
          <Card {...post} />
        ))}
      </ul>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500">暂无定价分析文章，敬请期待！</p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>